---
const nav = [
  { href: '/', label: 'TTS Tool' },
  { href: '/languages/text-to-speech-spanish/', label: 'Spanish' },
  { href: '/languages/text-to-speech-chinese/', label: 'Chinese' },
  { href: '/languages/text-to-speech-japanese/', label: 'Japanese' },
  { href: '/alternatives/', label: 'Compare' },
  { href: '/faq/', label: 'FAQ' },
];
---

<header class="border-b border-slate-200 bg-white sticky top-0 z-20">
  <div class="mx-auto flex max-w-5xl items-center justify-between px-4 py-4">
    <a href="/" class="flex items-center gap-2 text-lg font-bold text-brand-700">
      <span class="inline-block h-6 w-6 rounded bg-brand-600"></span>
      TextToSpeech.Online
    </a>
    <nav class="hidden gap-6 text-sm font-medium text-slate-600 md:flex">
      {nav.map((item) => (
        <a href={item.href} class="hover:text-brand-600">{item.label}</a>
      ))}
    </nav>
    <a
      href="#premium"
      class="rounded-full bg-brand-600 px-4 py-2 text-sm font-semibold text-white hover:bg-brand-700"
    >
      Go Premium
    </a>
  </div>
  <nav class="flex gap-4 overflow-x-auto border-t border-slate-100 px-4 py-2 text-sm font-medium text-slate-600 md:hidden">
    {nav.map((item) => (
      <a href={item.href} class="whitespace-nowrap hover:text-brand-600">{item.label}</a>
    ))}
  </nav>
</header>
