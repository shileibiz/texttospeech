---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import TtsTool from '../components/TtsTool.astro';
import PremiumCta from '../components/PremiumCta.astro';

export interface Props {
  title: string;
  description: string;
  heading: string;
  intro: string;
  langCode: string;
  langLabel: string;
  slug: string;
  bullets: string[];
  faqs: { q: string; a: string }[];
}

const {
  title,
  description,
  heading,
  intro,
  langCode,
  langLabel,
  slug,
  bullets,
  faqs,
} = Astro.props;

const canonical = new URL(`/languages/${slug}/`, Astro.site).href;

const hreflangs = [
  { lang: 'en', href: new URL('/', Astro.site).href },
  { lang: 'x-default', href: new URL('/', Astro.site).href },
  { lang: langCode.split('-')[0], href: canonical },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: `${langLabel} Text to Speech — TextToSpeech.Online`,
  url: canonical,
  applicationCategory: 'MultimediaApplication',
  operatingSystem: 'Any (Web Browser)',
  description,
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'USD',
  },
};
---

<Layout
  title={title}
  description={description}
  canonical={canonical}
  hreflangs={hreflangs}
  jsonLd={jsonLd}
>
  <Header />
  <main class="mx-auto max-w-5xl px-4 py-10">
    <section class="text-center">
      <h1 class="text-3xl font-extrabold text-slate-900 sm:text-4xl">{heading}</h1>
      <p class="mx-auto mt-4 max-w-2xl text-lg text-slate-600">{intro}</p>
    </section>

    <div class="mt-8">
      <TtsTool defaultLang={langCode} placeholder={`Type ${langLabel} text here...`} />
    </div>

    <section class="mt-16 grid gap-6 sm:grid-cols-2">
      {bullets.map((b) => (
        <div class="rounded-xl border border-slate-200 p-4 text-sm text-slate-600">{b}</div>
      ))}
    </section>

    <section class="mt-16">
      <h2 class="text-2xl font-bold text-slate-900">{langLabel} text to speech FAQ</h2>
      <div class="mt-6 space-y-4">
        {faqs.map((item) => (
          <details class="rounded-xl border border-slate-200 p-4">
            <summary class="cursor-pointer font-medium text-slate-800">{item.q}</summary>
            <p class="mt-2 text-sm text-slate-600">{item.a}</p>
          </details>
        ))}
      </div>
    </section>

    <PremiumCta />
  </main>
  <Footer />
</Layout>
