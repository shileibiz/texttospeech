---
import LanguagePage from '../../components/LanguagePage.astro';

const title = 'Spanish Text to Speech Online (Español) — Free TTS | TextToSpeech.Online';
const description =
  'Free Spanish text to speech. Type Spanish text and hear it read aloud with natural voices — no sign-up, no watermark, works in your browser.';

const bullets = [
  'Supports Spain (es-ES), Mexico (es-MX), and other regional Spanish voices available in your browser.',
  'Adjustable speed and pitch for language learners and content creators.',
  'Handy for pronunciation practice, video voiceovers, and screen readers.',
  'Runs 100% locally — your Spanish text never leaves your device.',
];

const faqs = [
  {
    q: '¿Es gratis convertir texto a voz en español?',
    a: 'Sí, la conversión básica de texto a voz es completamente gratuita e ilimitada.',
  },
  {
    q: 'Which Spanish accents are supported?',
    a: 'Available accents depend on your browser and OS voice packs, and typically include Spain, Mexico, and Latin American Spanish voices.',
  },
  {
    q: 'Can I use this for learning Spanish pronunciation?',
    a: 'Yes — slow down the speed slider to hear words more clearly, ideal for language learners.',
  },
];
---

<LanguagePage
  title={title}
  description={description}
  heading="Spanish Text to Speech (Texto a Voz)"
  intro="Type or paste Spanish text and hear it spoken aloud. Free, unlimited — good for language learners, content creators, and accessibility."
  langCode="es-ES"
  langLabel="Spanish"
  slug="text-to-speech-spanish"
  bullets={bullets}
  faqs={faqs}
/>
